# ============================================================================
# Instagram Unfollowers Tracker - Environment Configuration
# Copy to .env and edit values as needed
# ============================================================================

# Port the dashboard will be exposed on (your host port → container port 8000)
APP_PORT=8000

# ----- Home Assistant Integration -----
# Base URL of your Home Assistant instance (no trailing slash)
HA_WEBHOOK_URL=http://192.168.1.107:8123

# The webhook ID configured in your Home Assistant automation.
# The container will POST to {HA_WEBHOOK_URL}/api/webhook/{HA_WEBHOOK_ID}
HA_WEBHOOK_ID=instagram_unfollowers

# Enable/disable webhook firing (true/false)
HA_WEBHOOK_ENABLED=true

# ----- Security -----
# Used to encrypt stored Instagram sessions at rest.
# Generate a new one with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=CHANGE_ME_GENERATE_A_FERNET_KEY

# ----- App Behavior -----
# Timezone for scheduled scans (IANA name, e.g. Europe/London, America/New_York)
TIMEZONE=UTC

# How many historical snapshots to retain per account (older ones are pruned)
SNAPSHOT_RETENTION_DAYS=90

# Log verbosity: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ----- Instagram API Timing (milliseconds) -----
# These match the defaults from the original InstagramUnfollowers tool.
# Adjust if you're getting rate-limited (higher = safer, slower).
IG_TIME_BETWEEN_CYCLES_MS=1000
IG_TIME_AFTER_FIVE_CYCLES_MS=10000
